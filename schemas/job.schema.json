{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xxzzzzy/codex-job-search-cn/schemas/job.schema.json",
  "title": "Job",
  "type": "object",
  "required": ["id", "company", "role", "duties", "requirements", "source", "imported_at"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "company": {"type": "string"},
    "role": {"type": "string"},
    "department": {"type": "string"},
    "location": {"type": "string"},
    "recruitment_type": {
      "enum": ["campus", "experienced", "internship", "public-sector", "other"]
    },
    "employer_type": {
      "enum": ["private", "state-owned", "public-institution", "multinational", "startup", "research", "other"]
    },
    "duties": {"type": "array", "items": {"type": "string"}},
    "requirements": {
      "type": "object",
      "required": ["required", "preferred"],
      "properties": {
        "required": {"type": "array", "items": {"type": "string"}},
        "preferred": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "compensation": {"type": "string"},
    "deadline": {"type": "string"},
    "source": {
      "type": "object",
      "required": ["kind", "reference"],
      "properties": {
        "kind": {"enum": ["pasted-text", "url", "screenshot", "document", "email", "other"]},
        "reference": {"type": "string"},
        "captured_text_path": {"type": "string"}
      },
      "additionalProperties": false
    },
    "imported_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
